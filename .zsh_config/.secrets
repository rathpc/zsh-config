#!/usr/bin/env zsh
# 1Password integration
# This file stores secrets and integrations with 1Password CLI
# Source this file only when needed via the opload alias

# Example: Store your 1Password secrets here in the format:
# export MY_SECRET_VAR="op://vault/item/field"
# Then run: opload
# to inject the actual value from 1Password

# Add your secret environment variables below (format: export VAR_NAME="op://vault/item/field")
# Example:
# export GITHUB_TOKEN="op://Private/GitHub/credential"
# export DOCKER_USERNAME="op://Private/Docker/username"
# export DOCKER_PASSWORD="op://Private/Docker/password"

# Note: Never commit actual secret values to this file.
# Always use 1Password field references in the `op://vault/item/field` format
