# User configuration (do not commit personal settings)
.zsh_config/local/
.zsh_config/secrets/

# Backups from install script (timestamped: .zsh_config.bak.YYYYMMDD-HHMMSS)
*.bak
*.bak.*
*.backup

# Editor swap files
*.swp
*.swo
*~

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Node modules (if needed for tooling)
node_modules/
npm-debug.log
yarn-error.log

# Logs
*.log
